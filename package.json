{
  "name": "hmpps-activities-management",
  "version": "0.0.1",
  "description": "Hmpps Activities Management",
  "repository": "git@github.com:ministryofjustice/hmpps-activities-management.git",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "watch-ts": "tsc -w",
    "build": "node esbuild/esbuild",
    "start": "node $NODE_OPTIONS -r dotenv/config dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild --watch",
    "start-feature": "export $(cat feature.env) && node $NODE_DEBUG_OPTION dist/server.js | bunyan -o short",
    "start-feature:dev": "node esbuild/esbuild --watch --env feature.env",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --cache --max-warnings 0 --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "NODE_ENV=unit-test TZ=utc NODE_OPTIONS=\"--max_old_space_size=4096 --experimental-vm-modules\" jest --runInBand --detectOpenHandles --collectCoverage=true --testPathPatterns='(server|frontend)/.*'",
    "test:ci": "jest --runInBand",
    "security_audit": "better-npm-audit audit",
    "int-test": "cypress run --config video=false",
    "int-test-ui": "cypress open --config watchForFileChanges=false",
    "clean": "rm -rf dist node_modules",
    "rebuild": "npm run clean && npm i && npm run build",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "lint-staged": {
    "*.{ts,js,css}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@microsoft/applicationinsights-web": "3.4.1",
    "@ministryofjustice/frontend": "^8.0.1",
    "@ministryofjustice/hmpps-auth-clients": "1.0.2",
    "@ministryofjustice/hmpps-connect-dps-components": "5.5.0",
    "@ministryofjustice/hmpps-rest-client": "1.2.1",
    "@types/express-serve-static-core": "5.1.1",
    "@types/lodash": "4.17.24",
    "accessible-autocomplete": "^3.0.1",
    "agentkeepalive": "^4.6.0",
    "applicationinsights": "^2.9.8",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "express-session": "1.19.0",
    "govuk-frontend": "5.14.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "isbinaryfile": "^6.0.0",
    "jwt-decode": "^4.0.0",
    "libphonenumber-js": "1.13.0",
    "lodash": "4.18.1",
    "multer": "^2.1.1",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "1.0.3",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.4",
    "@tsconfig/node24": "24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "^0.0.40",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest-when": "^3.5.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "24.12.3",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/sinon": "^21.0.1",
    "@types/superagent": "^8.1.9",
    "axe-core": "^4.11.4",
    "better-npm-audit": "^3.11.0",
    "cheerio": "1.2.0",
    "cypress": "15.14.2",
    "cypress-axe": "^1.7.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-split": "1.24.31",
    "esbuild": "0.28.0",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-date": "^1.1.6",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jest-when": "^4.0.3",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "mocha-junit-reporter": "^2.2.1",
    "nock": "^13.5.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "serialize-javascript": "~7.0.5",
    "js-yaml": "^4.1.1",
    "validator": "~13.15.35",
    "@types/validator": "~13.15.10",
    "path-to-regexp": "8.4.2",
    "diff": "^9.0.0",
    "@actions/http-client": "^3.0.2",
    "undici": "^8.2.0"
  }
}
