{% extends "layout.njk" %}

{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "partials/activities/activity-journey-caption.njk" import activityJourneyCaption %}

{% set pageTitle = "Activity category - Activities - DPS" %}
{% set pageId = 'category-page' %}
{% set jsBackLink = true %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <form method="POST">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
                {{ activityJourneyCaption(createJourney) }}
                {{ govukRadios({
                    fieldset: {
                        legend: {
                            text: "Select the type of activity",
                            isPageHeading: true,
                            classes: "govuk-fieldset__legend--l"
                        }
                    },
                    name: "type",
                    errorMessage: validationErrors | findError('type'),
                    items: [
                        {
                            value: "internal",
                            text: "In-prison activity",
                            checked: formResponses.type == 'internal' or createJourney.type == 'internal'
                        },
                        {
                            value: "external",
                            text: "Outside activity",
                            hint: {
                                text: "For activities that people leave the prison grounds to go to."
                            },
                            checked: formResponses.type == 'external' or createJourney.type == 'external'
                        }
                    ]
                }) }}
                {{ govukButton({
                    text: "Continue"
                }) }}
            </form>
        </div>
    </div>
{% endblock %}